import json
import shutil
import time
import re
import msvcrt
from pathlib import Path
from datetime import datetime, timedelta
from collections import defaultdict


STOP_REQUESTED = False


BASE_DIR = Path.cwd()
STATE_DIR = BASE_DIR / "state"
QUARANTINE_DIR = BASE_DIR / "quarantine"
TRUSTED_FILE = STATE_DIR / "trusted.json"

QUARANTINE_DAYS = 7
RISK_THRESHOLD = 30


DANGEROUS_PERMISSIONS = {
    "management": ("Управление расширениями", 25),
    "tabs": ("Доступ к вкладкам", 15),
    "history": ("История браузера", 15),
    "cookies": ("Cookies", 20),
    "webRequest": ("Сетевые запросы", 20),
    "webRequestBlocking": ("Блокировка запросов", 25),
    "<all_urls>": ("Доступ ко всем сайтам", 30),
    "scripting": ("Выполнение скриптов", 20),
    "storage": ("Локальное хранилище", 10),
}


CODE_PATTERNS = {
    r"\beval\s*\(": ("eval()", 15),
    r"\bFunction\s*\(": ("Function()", 15),
    r"document\.createElement\(['\"]script['\"]\)": ("Dynamic script", 10),
    r"\bfetch\s*\(": ("Network request", 10),
    r"\bXMLHttpRequest\b": ("Network request", 10),
    r"\\u[0-9a-fA-F]{4}": ("Obfuscation", 10),
}


def init_environment():
    STATE_DIR.mkdir(exist_ok=True)
    QUARANTINE_DIR.mkdir(exist_ok=True)
    if not TRUSTED_FILE.exists():
        TRUSTED_FILE.write_text("[]", encoding="utf-8")


def chrome_extensions_dir() -> Path:
    return Path.home() / "AppData/Local/Google/Chrome/User Data/Default/Extensions"


def load_trusted() -> set:
    try:
        return set(json.loads(TRUSTED_FILE.read_text(encoding="utf-8")))
    except:
        return set()

def save_trusted(trusted: set):
    TRUSTED_FILE.write_text(
        json.dumps(list(trusted), indent=2, ensure_ascii=False),
        encoding="utf-8"
    )


def state_file(ext_id: str) -> Path:
    return STATE_DIR / f"{ext_id}.json"

def load_state(ext_id: str):
    p = state_file(ext_id)
    if not p.exists():
        return None
    try:
        return json.loads(p.read_text(encoding="utf-8"))
    except:
        return None

def save_state(ext_id: str, report: dict):
    state_file(ext_id).write_text(
        json.dumps(report, indent=2, ensure_ascii=False),
        encoding="utf-8"
    )


def quarantine_base(ext_id: str) -> Path:
    return QUARANTINE_DIR / ext_id

def quarantine_copy(ext_id: str, version_dir: Path, name: str, version: str):
    qbase = quarantine_base(ext_id)
    qbase.mkdir(exist_ok=True)

    target = qbase / version_dir.name
    if target.exists():
        shutil.rmtree(target)

    shutil.copytree(version_dir, target)

    meta = {
        "id": ext_id,
        "name": name,
        "version": version,
        "quarantined_at": datetime.now().isoformat()
    }

    (qbase / "meta.json").write_text(
        json.dumps(meta, indent=2, ensure_ascii=False),
        encoding="utf-8"
    )

def restore_from_quarantine(ext_id: str, version_dir: Path):
    chrome_dir = chrome_extensions_dir() / ext_id
    chrome_dir.mkdir(exist_ok=True)

    target = chrome_dir / version_dir.name
    if target.exists():
        shutil.rmtree(target)

    shutil.copytree(version_dir, target)


def cleanup_quarantine():
    now = datetime.now()
    for item in QUARANTINE_DIR.iterdir():
        meta = item / "meta.json"
        if not meta.exists():
            continue
        try:
            data = json.loads(meta.read_text(encoding="utf-8"))
            t = datetime.fromisoformat(data["quarantined_at"])
        except:
            continue
        if now - t > timedelta(days=QUARANTINE_DAYS):
            shutil.rmtree(item)


def analyze_extension(ext_dir: Path) -> dict | None:
    manifest = ext_dir / "manifest.json"
    if not manifest.exists():
        return None

    try:
        data = json.loads(manifest.read_text(encoding="utf-8"))
    except:
        return None

    name = data.get("name", "Unknown")
    version = data.get("version", "0")

    perm_score = 0
    perm_details = []

    perms = data.get("permissions", []) + data.get("host_permissions", [])
    for p in perms:
        if p in DANGEROUS_PERMISSIONS:
            desc, score = DANGEROUS_PERMISSIONS[p]
            perm_score += score
            perm_details.append((p, desc, score))

    code_score = 0
    patterns = defaultdict(lambda: {"count": 0, "score": 0})

    for js in ext_dir.rglob("*.js"):
        try:
            text = js.read_text(encoding="utf-8", errors="ignore")
        except:
            continue
        for pat, (desc, score) in CODE_PATTERNS.items():
            hits = len(re.findall(pat, text))
            if hits:
                patterns[(desc, js.name)]["count"] += hits
                patterns[(desc, js.name)]["score"] += hits * score
                code_score += hits * score

    return {
        "name": name,
        "version": version,
        "risk": perm_score + code_score,
        "permissions": perm_details,
        "patterns": patterns,
        "timestamp": datetime.now().isoformat()
    }


def print_report(report: dict):
    print("\nОТЧЁТ АНАЛИЗА")
    print(f"Название: {report['name']}")
    print(f"Версия: {report['version']}")
    print(f"Уровень риска: {report['risk']}")

    if report["permissions"]:
        print("\nОпасные разрешения:")
        for p, desc, score in report["permissions"]:
            print(f" - {p} → {desc} (+{score})")

    if report["patterns"]:
        print("\nПодозрительный код:")
        for (desc, file), info in report["patterns"].items():
            print(f" - {desc}, файл {file} x{info['count']} (+{info['score']})")

    print("-" * 60)


def scan_all_extensions(allow_quit=True):
    global STOP_REQUESTED
    STOP_REQUESTED = False

    base = chrome_extensions_dir()
    trusted = load_trusted()

    if not base.exists():
        print("Каталог Chrome не найден")
        return

    print("\nСканирование (q — выход)\n")

    for ext in base.iterdir():
        if allow_quit and msvcrt.kbhit():
            if msvcrt.getwch().lower() == "q":
                STOP_REQUESTED = True
                print("Сканирование остановлено")
                return

        versions = sorted(ext.iterdir(), reverse=True)
        if not versions:
            continue

        latest = versions[0]

        quarantine_copy(ext.name, latest, ext.name, latest.name)
        qver = quarantine_base(ext.name) / latest.name

        report = analyze_extension(qver)
        if not report:
            continue

        print_report(report)

        prev = load_state(ext.name)
        old_risk = prev.get("risk", 0) if isinstance(prev, dict) else 0
        new_risk = report.get("risk", 0)

        if ext.name in trusted and new_risk <= old_risk:
            restore_from_quarantine(ext.name, qver)
            save_state(ext.name, report)
            shutil.rmtree(quarantine_base(ext.name))
            continue

        if prev and new_risk <= old_risk:
            restore_from_quarantine(ext.name, qver)
            save_state(ext.name, report)
            shutil.rmtree(quarantine_base(ext.name))
            continue

        if new_risk <= RISK_THRESHOLD:
            restore_from_quarantine(ext.name, qver)
            save_state(ext.name, report)
            shutil.rmtree(quarantine_base(ext.name))


def quarantine_menu():
    trusted = load_trusted()

    while True:
        items = [d for d in QUARANTINE_DIR.iterdir() if (d / "meta.json").exists()]
        if not items:
            print("Карантин пуст")
            return

        print("\nКАРАНТИН:")
        for i, d in enumerate(items, 1):
            meta = json.loads((d / "meta.json").read_text(encoding="utf-8"))
            print(f"{i}. {meta['name']} (v{meta['version']})")

        print("Выберите номер для восстановления или q")
        c = input("> ").strip()
        if c.lower() == "q":
            return

        try:
            d = items[int(c) - 1]
        except:
            continue

        version_dir = next(p for p in d.iterdir() if p.is_dir())
        restore_from_quarantine(d.name, version_dir)

        trusted.add(d.name)
        save_trusted(trusted)

        shutil.rmtree(d)
        print("Восстановлено и помечено как доверенное\n")


def untrust_menu():
    trusted = load_trusted()
    if not trusted:
        print("Нет доверенных расширений")
        return

    lst = list(trusted)
    for i, t in enumerate(lst, 1):
        print(f"{i}. {t}")

    try:
        idx = int(input("> ")) - 1
        trusted.remove(lst[idx])
        save_trusted(trusted)
        print("Метка доверия снята")
    except:
        pass


def monitoring_loop():
    global STOP_REQUESTED
    STOP_REQUESTED = False

    print("Мониторинг запущен (q — выход)")
    seen = {}

    while True:
        if msvcrt.kbhit():
            if msvcrt.getwch().lower() == "q":
                STOP_REQUESTED = True
                print("Мониторинг остановлен")
                return

        base = chrome_extensions_dir()
        for ext in base.iterdir():
            if STOP_REQUESTED:
                return

            versions = sorted(ext.iterdir(), reverse=True)
            if not versions:
                continue

            latest = versions[0].name
            if seen.get(ext.name) != latest:
                seen[ext.name] = latest
                scan_all_extensions(allow_quit=False)

        time.sleep(5)


def main():
    init_environment()
    cleanup_quarantine()

    while True:
        print("""
1 — Сканировать все расширения
2 — Карантин
3 — Мониторинг обновлений
4 — Снять доверие
0 — Выход
""")
        c = input("> ").strip()

        if c == "1":
            scan_all_extensions()
        elif c == "2":
            quarantine_menu()
        elif c == "3":
            monitoring_loop()
        elif c == "4":
            untrust_menu()
        elif c == "0":
            break

if __name__ == "__main__":
    main()
